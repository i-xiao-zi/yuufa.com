{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": ["NODE_ENV"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "public/**",
        "client-dist/**",
        "static/**"
      ]
    },
    "web": {
      "dependsOn": ["^build"],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**"]
    },
    "api": {
      "dependsOn": ["web"],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**", ".out/**", "public/**"]
    },
    "lint": {},
    "dev": {
      "cache": true,
      "persistent": true
    }
  }
}
